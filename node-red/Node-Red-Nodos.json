    {
        "id": "af45366120a9b4f4",
        "type": "function",
        "z": "587a0111ca079dbc",
        "name": "function INFLUX",
        "func": "// 1. Capturar y asegurar formato JSON\nlet datos = msg.payload;\n\nif (typeof datos === 'string') {\n    try {\n        datos = JSON.parse(datos);\n    } catch (e) {\n        node.error(\"Error parseando JSON\", msg);\n        return null;\n    }\n}\nif (!datos) return null;\n\n// 2. Extraer Flujos (¡OJO! Ya vienen en Litros desde la LilyGO)\nconst flujo1Litros = Number(datos.flujo1 || 0);\nconst flujo2Litros = Number(datos.flujo2 || 0);\n\n// 3. Calcular Consumo Neto (en Litros)\nconst consumoReal = Math.max(0, flujo1Litros - flujo2Litros);\n\n// 4. Variables primarias adicionales\nlet latReal = (datos.lat !== undefined) ? Number(datos.lat) : null;\nlet lonReal = (datos.lng !== undefined) ? Number(datos.lng) : null;\nconst reedReal = (datos.reed !== undefined) ? Number(datos.reed) : 1;\nconst statusReal = datos.status || \"OPERACION_NORMAL\";\n\n// 5. Respaldo Dinámico de Ubicación (SIM7070)\nif (latReal === 0 || lonReal === 0 || latReal === null || lonReal === null) {\n    latReal = (datos.lat_sim !== undefined) ? Number(datos.lat_sim) : null;\n    lonReal = (datos.lon_sim !== undefined) ? Number(datos.lon_sim) : null;\n}\n\n// Bloqueo de seguridad si ningún GPS tiene datos coherentes\nif (latReal === null || lonReal === null || latReal === 0) {\n    node.warn(\"⚠️ Registro omitido en InfluxDB: Sin coordenadas.\");\n    return null;\n}\n\n// 6. Estructurar payload para InfluxDB Out\nmsg.measurement = \"monitoreo_diesel_tics\";\nmsg.payload = [\n    {\n        // FIELDS (Valores numéricos que Grafana va a graficar)\n        latitud: latReal,\n        longitud: lonReal,\n        estado_tapa: reedReal,\n        flujo1: flujo1Litros,\n        flujo2: flujo2Litros,\n        consumo_actual: consumoReal\n    },\n    {\n        // TAGS (Metadatos)\n        unidad: \"Camion_Kiwi\",\n        propietario: \"Isai_TICS\",\n        sensor: \"Hardware_LilyGO_Real\",\n        diagnostico: statusReal\n    }\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 140,
        "y": 420,
        "wires": [
            [
                "97f3243e0c145d97",
                "c35012bb08fef63d"
            ]
        ]
    },
