    {
        "id": "f880abf3a08b208e",
        "type": "function",
        "z": "587a0111ca079dbc",
        "name": "function 8",
        "func": "var datos = msg.payload;\n\n// 1. Asegurar que los datos sean un objeto JSON\nif (typeof datos === 'string') {\n  try {\n    datos = JSON.parse(datos);\n  } catch (e) {\n    node.error(\"Error parseando JSON de LilyGO\");\n  }\n}\n\n// 2. Extraer latitud y longitud (usando 'lng' como manda tu MQTT)\n// Si no hay datos, se queda en la última posición conocida o base\nlet lat = (datos && datos.lat !== undefined) ? Number(datos.lat) : 20.0283;\nlet lon = (datos && datos.lng !== undefined) ? Number(datos.lng) : -99.2250;\n\n// 3. Objeto para el Mapa (Marcador)\n// Nota: Eliminamos el objeto \"command\" para que el mapa NO se mueva solo\nmsg.payload = {\n  \"name\": \"Piña\",\n  \"lat\": lat,\n  \"lon\": lon,\n  \"icon\": \"truck\",\n  \"iconColor\": \"#FFC107\",\n  \"layer\": \"Unidades\"\n};\n\n// 4. Texto con diseño para el Dashboard (Ubicación azul arriba)\n// Usamos .toFixed(6) para captar la precisión real del GPS\nmsg.payload_text = `\n<div style=\"font-family:'Roboto Mono', monospace; color: rgb(68, 180, 255); font-size:14px;\">\n  <div style=\"display:flex; justify-content:space-between;\">\n    <span>Latitud:</span>\n    <b>${lat.toFixed(6)}</b> \n  </div>\n  <div style=\"display:flex; justify-content:space-between; margin-top:4px;\">\n    <span>Longitud:</span>\n    <b>${lon.toFixed(6)}</b>\n  </div>\n</div>\n`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 500,
        "y": 1260,
        "wires": [
            []
        ]
    },
    {
        "id": "8b29cfccbb61804c",
        "type": "function",
        "z": "587a0111ca079dbc",
        "name": "function 9",
        "func": "var datos = msg.payload;\nif (typeof datos === 'string') datos = JSON.parse(datos);\n\nif (datos && datos.alerta !== undefined) {\n    if (datos.alerta == 1) {\n        msg.payload = \"CERRADA\";\n        msg.background = \"green\"; // Cerrada = Seguro\n    } else {\n        msg.payload = \"ABIERTA\";\n        msg.background = \"red\";   // Abierta = Alerta!\n    }\n} else {\n    msg.payload = \"SIN DATO\";\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
