        "func": "if (msg.payload && msg.payload.length > 0) {\n    // Extraemos el valor del resultado de InfluxDB\n    let total = msg.payload[0]._value;\n    msg.payload = total.toFixed(2) + \" Litros\";\n} else {\n    msg.payload = \"0 Litros\";\n}\nreturn msg;",
