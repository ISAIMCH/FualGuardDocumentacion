    {
        "id": "e6036442023698c2",
        "type": "function",
        "z": "587a0111ca079dbc",
        "name": "function 1",
        "func": "const datos = msg.payload;\nif (!datos) return null;\n\n// =========================================================\n// ⏱️ CÁLCULO DE TIEMPO TRANSCURRIDO PARA FLUJO (L/min)\n// =========================================================\nconst currentTime = Date.now();\n// Recuperamos el tiempo exacto en el que llegó el paquete anterior\nlet lastTime = context.get(\"lastTime\");\ncontext.set(\"lastTime\", currentTime); // Guardamos el tiempo actual para el siguiente ciclo\n\n// 1. Convertir Pulsos a Litros (Factor: 450 pulsos = 1 Litro) \nconst f1_L = Number(datos.flujo1 || 0) / 450; \nconst f2_L = Number(datos.flujo2 || 0) / 450;\n\nlet f1_L_min = 0;\nlet f2_L_min = 0;\n\n// 2. Calcular la tasa de flujo en L/min (Solo si existe un paquete de datos previo)\nif (lastTime) {\n  let deltaMin = (currentTime - lastTime) / 60000; // Convertir la diferencia (ms) a minutos\n\n  // Evitamos divisiones por cero en caso de que lleguen paquetes instantáneos\n  if (deltaMin > 0) {\n    f1_L_min = f1_L / deltaMin;\n    f2_L_min = f2_L / deltaMin;\n  }\n}\n\nconst status = datos.status || \"OPERACION_NORMAL\";\n\n// Inferir el estado de la tapa basándonos en el diagnóstico\nlet tapaAbierta = status.includes(\"TAPA\") || status.includes(\"APERTURA\");\n\n// 3. Coordenadas GPS (Directas del Transmisor Heltec)\nlet lat = Number(datos.lat || 0);\nlet lon = Number(datos.lng || 0);\n\n// Coordenadas de respaldo por si el Heltec pierde señal satelital temporalmente\nif (lat === 0 || lon === 0) {\n  lat = 20.0283;\n  lon = -99.2250;\n}\n\n// =========================================================\n// 📤 CONFIGURACIÓN DE LAS SALIDAS DEL NODO\n// =========================================================\n\n// --- SALIDA 1: Ubicación (Para el Mapa) ---\nconst msgMap = {\n  payload: { \"name\": \"Tanque 01\", \"lat\": lat, \"lon\": lon, \"icon\": \"truck\", \"iconColor\": \"#FFC107\", \"layer\": \"Unidades\" },\n  payload_text: `\n    <div style=\"font-family:'Roboto Mono', monospace; color: rgb(68, 180, 255); font-size:14px;\">\n      <div style=\"display:flex; justify-content:space-between;\">\n        <span>Latitud:</span><b>${lat.toFixed(6)}</b> \n      </div>\n      <div style=\"display:flex; justify-content:space-between; margin-top:4px;\">\n        <span>Longitud:</span><b>${lon.toFixed(6)}</b>\n      </div>\n    </div>`\n};\n\n// --- SALIDA 2: Estado de la Tapa ---\nlet textoTapa = tapaAbierta ? \"ABIERTA\" : \"CERRADA\";\nlet colorTapa = tapaAbierta ? \"red\" : \"green\";\n\nconst msgTapa = { payload: textoTapa, background: colorTapa };\n\n// --- SALIDA 3: Flujo Ida (Redondeado a 2 decimales en L/min) ---\nconst msgIda = { payload: Number(f1_L_min.toFixed(2)), topic: \"Ida (L/min)\" };\n\n// --- SALIDA 4: Flujo Retorno (Redondeado a 2 decimales en L/min) ---\nconst msgRetorno = { payload: Number(f2_L_min.toFixed(2)), topic: \"Retorno (L/min)\" };\n\n// --- SALIDA 5: Diagnóstico del Sistema y Alertas ---\nlet uiColor = \"#2ECC71\";\nlet dispararNotificacion = null;\n\nif (status.startsWith(\"ALERTA\")) {\n  uiColor = \"#FF3333\";\n  dispararNotificacion = { payload: \"🚨 ¡ATENCIÓN! Anomalía: \" + status.replace(/_/g, \" \") };\n} else if (status === \"APAGADO_SEGURO\") {\n  uiColor = \"#8A8A8A\";\n}\nconst msgStatus = { payload: status.replace(/_/g, \" \"), color: uiColor };\n\nreturn [msgMap, msgTapa, msgIda, msgRetorno, [msgStatus, dispararNotificacion]];",
        "outputs": 5,
        "timeout": 0,
        "noerr": 0,
